# ============================================================
# CRM Portal Environment Configuration
# ============================================================

# Required in production: Vercel KV (Upstash Redis) connection
# If you attach a Vercel KV/Redis integration, these are injected automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Optional seed data (only used to seed KV if empty on first boot)
# Format: code:domain:product:license_type (comma separated)
# product can be: lostry, plugin_bundle, theme_builder, mobile_app
# license_type can be: Regular license, Extended license
PURCHASE_CODES=FLYINGDARKDEVXGAURAV8651829629GAURAV:*:lostry:Extended license

# Admin API key for managing licenses via dashboard
ADMIN_API_KEY=change-me

# CORS allowlist (comma-separated). Leave empty to allow all origins.
ALLOWED_ORIGINS=http://localhost:3000,https://crm-portal-jade.vercel.app

# Rate limit for /api/verify
VERIFY_RATE_LIMIT_MAX=60
VERIFY_RATE_LIMIT_WINDOW_SEC=60

# Port for local development
PORT=3000
